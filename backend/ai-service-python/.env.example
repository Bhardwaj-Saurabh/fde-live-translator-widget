# Python AI service config — copy to `.env`

# Primary provider: OpenRouter (cheaper per-token routing). When this key is
# set, translations go through OpenRouter first, using OPENROUTER_MODEL.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

# Fallback provider: Anthropic direct (also the only provider if no
# OpenRouter key is set), using MODEL.
ANTHROPIC_API_KEY=
MODEL=claude-sonnet-4-6

TRANSLATION_DB_PATH=translations.db
